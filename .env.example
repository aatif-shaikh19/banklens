# BankLens 2.0 — Environment Variables Template
# Copy this file: cp .env.example .env
# Then fill in your real values in .env
# NEVER commit .env to git

# ── GCP / BigQuery ───────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_DATASET_RAW=banklens_raw
GCP_DATASET_MARTS=banklens_marts
# Path to your service account JSON key (store OUTSIDE the repo)
GOOGLE_APPLICATION_CREDENTIALS=/home/your-username/.config/banklens/service_account.json

# ── Snowflake ────────────────────────────────────────────────────────
# Account format: xy12345.us-east-1  (from your welcome email)
SNOWFLAKE_ACCOUNT=your-account.region
SNOWFLAKE_USER=banklens_service
SNOWFLAKE_PASSWORD=your-snowflake-password
SNOWFLAKE_DATABASE=BANKLENS_DB
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# ── OpenAI (for PandasAI) ────────────────────────────────────────────
# AI Layer — Groq (free at console.groq.com, no credit card needed)
GROQ_API_KEY=gsk_your_groq_key_here
# OPENAI_API_KEY=sk-...  # Optional alternative
OPENAI_API_KEY=sk-...

# ── Email (for Airflow failure alerts) ───────────────────────────────
SMTP_EMAIL=aatif.shaikh2004@gmail.com
# Use Gmail App Password (not your real password)
# Create at: myaccount.google.com/apppasswords
SMTP_PASSWORD=your-16-char-app-password

# ── FastAPI ──────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=generate-a-random-32-char-string-here

# ── Rate Limiting ────────────────────────────────────────────────────
MAX_REQUESTS_PER_MINUTE=60
